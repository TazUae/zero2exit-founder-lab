# Zero2Exit Frontend
# Copy to .env.local for local development

# Backend API URL — must point to the Fastify server (NOT the Next.js app)
# Local dev: backend runs on 3000, frontend on 3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Authentik / NextAuth
AUTHENTIK_ISSUER=https://auth.z2e.zaidan-group.com/application/o/zero2exit/
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://z2e.zaidan-group.com

# Playwright E2E
PLAYWRIGHT_BASE_URL=http://localhost:3001
PLAYWRIGHT_TEST_FOUNDER_ID=
PLAYWRIGHT_BYPASS_SECRET=playwright-bypass-secret-zero2exit-dev-only
