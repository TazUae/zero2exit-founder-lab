datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Founder {
  id               String   @id @default(cuid())
  clerkUserId      String   @unique @map("clerk_user_id")
  email            String
  name             String?
  language         String   @default("en")
  stage            String?
  plan             String   @default("launch")
  stripeCustomerId String?  @map("stripe_customer_id")
  s3BucketName     String?  @map("s3_bucket_name")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  onboardingResponse  OnboardingResponse?
  moduleProgress      ModuleProgress[]
  ideaValidation      IdeaValidation?
  legalStructure      LegalStructure?
  documents           Document[]
  coachSessions       CoachSession[]
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  knowledgeNodes      KnowledgeNode[]
  knowledgeEdges      KnowledgeEdge[]
  roadmaps            FounderRoadmap[]

  @@map("founders")
}

model OnboardingResponse {
  id               String    @id @default(cuid())
  founderId        String    @unique @map("founder_id")
  responses        Json
  stageAssigned    String    @map("stage_assigned")
  modulePlan       Json      @map("module_plan")
  routingRationale String?   @map("routing_rationale")
  evaluatedAt      DateTime  @default(now()) @map("evaluated_at")
  nextEvalAt       DateTime? @map("next_eval_at")
  founder          Founder   @relation(fields: [founderId], references: [id])

  @@map("onboarding_responses")
}

model ModuleProgress {
  id           String    @id @default(cuid())
  founderId    String    @map("founder_id")
  moduleId     String    @map("module_id")
  status       String    @default("locked")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  outputs      Json?
  score        Int?
  lastActivity DateTime? @map("last_activity")
  founder      Founder   @relation(fields: [founderId], references: [id])

  @@unique([founderId, moduleId])
  @@index([founderId])
  @@map("module_progress")
}

model IdeaValidation {
  id                  String   @id @default(cuid())
  founderId           String   @unique @map("founder_id")
  businessDescription String   @map("business_description")
  objections          Json?
  marketSizing        Json?    @map("market_sizing")
  competitiveMap      Json?    @map("competitive_map")
  icpProfiles         Json?    @map("icp_profiles")
  scorecard           Json?
  shareCardUrl        String?  @map("share_card_url")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  founder             Founder  @relation(fields: [founderId], references: [id])

  @@map("idea_validations")
}

model LegalStructure {
  id                      String   @id @default(cuid())
  founderId               String   @unique @map("founder_id")
  recommendedJurisdiction String?  @map("recommended_jurisdiction")
  recommendedEntityType   String?  @map("recommended_entity_type")
  confidenceScore         Int?     @map("confidence_score")
  jurisdictionComparison  Json?    @map("jurisdiction_comparison")
  holdcoNeeded            Boolean? @map("holdco_needed")
  orgChart                Json?    @map("org_chart")
  legalRoadmap            Json?    @map("legal_roadmap")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  founder                 Founder  @relation(fields: [founderId], references: [id])

  @@map("legal_structures")
}

model Document {
  id                 String    @id @default(cuid())
  founderId          String    @map("founder_id")
  moduleId           String?   @map("module_id")
  docType            String    @map("doc_type")
  s3Key              String    @map("s3_key")
  s3Url              String?   @map("s3_url")
  docusignEnvelopeId String?   @map("docusign_envelope_id")
  docusignStatus     String    @default("draft") @map("docusign_status")
  signers            Json?
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  founder            Founder   @relation(fields: [founderId], references: [id])

  @@index([founderId])
  @@map("documents")
}

model CoachSession {
  id              String   @id @default(cuid())
  founderId       String   @map("founder_id")
  messages        Json     @default("[]")
  contextSnapshot Json?    @map("context_snapshot")
  language        String   @default("en")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  founder         Founder  @relation(fields: [founderId], references: [id])

  @@index([founderId])
  @@map("coach_sessions")
}

model Subscription {
  id                   String    @id @default(cuid())
  founderId            String    @map("founder_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  plan                 String
  status               String
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  founder              Founder   @relation(fields: [founderId], references: [id])

  @@map("subscriptions")
}

model AuditLog {
  id           String   @id @default(cuid())
  founderId    String?  @map("founder_id")
  actorType    String   @map("actor_type")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  founder      Founder? @relation(fields: [founderId], references: [id])

  @@index([founderId])
  @@index([action])
  @@map("audit_log")
}

model MarketResearch {
  id        String   @id @default(uuid())
  topic     String
  facts     Json
  sources   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([topic])
  @@map("market_research")
}

model FounderRoadmap {
  id        String   @id @default(uuid())
  founderId String   @map("founder_id")
  roadmap   Json
  createdAt DateTime @default(now()) @map("created_at")
  founder   Founder  @relation(fields: [founderId], references: [id])
  revisions RoadmapRevision[]

  @@index([founderId])
  @@map("founder_roadmaps")
}

model RoadmapRevision {
  id        String   @id @default(uuid())
  roadmapId String   @map("roadmap_id")
  version   Int
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  roadmap   FounderRoadmap @relation(fields: [roadmapId], references: [id])

  @@index([roadmapId])
  @@map("roadmap_revisions")
}

model KnowledgeNode {
  id        String   @id @default(uuid())
  founderId String   @map("founder_id")
  type      String
  title     String?
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  founder   Founder  @relation(fields: [founderId], references: [id])
  outgoing  KnowledgeEdge[] @relation("KnowledgeEdgeFrom")
  incoming  KnowledgeEdge[] @relation("KnowledgeEdgeTo")

  @@index([founderId, type])
  @@map("knowledge_nodes")
}

model KnowledgeEdge {
  id         String        @id @default(uuid())
  founderId  String        @map("founder_id")
  fromNodeId String        @map("from_node_id")
  toNodeId   String        @map("to_node_id")
  relation   String
  createdAt  DateTime      @default(now()) @map("created_at")
  founder    Founder       @relation(fields: [founderId], references: [id])
  fromNode   KnowledgeNode @relation("KnowledgeEdgeFrom", fields: [fromNodeId], references: [id])
  toNode     KnowledgeNode @relation("KnowledgeEdgeTo", fields: [toNodeId], references: [id])

  @@index([founderId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("knowledge_edges")
}




