NODE_ENV=development
PORT=3000

# LLM providers (at least one required)
# Task-aware routing: Gemini/DeepSeek (primary) → NVIDIA (secondary) → Groq (last resort — 100K tokens/day cap)

# Gemini 2.5 Flash — best reasoning, ~60 RPM burst, ~2K req/day free tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek-V3.2 — structured/legal reasoning, generous free tier (https://platform.deepseek.com)
# IMPORTANT: Add DEEPSEEK_API_KEY to Dokploy environment variables after getting key from platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Groq — fastest inference, 30 RPM, 100K tokens/day HARD LIMIT — last resort only (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM — reliable secondary, 40 RPM, ~1K credits/day (https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zero2exit
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/zero2exit

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_PREFIX=zero2exit-founder-

# DocuSign
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# Resend
RESEND_API_KEY=re_...

# Langfuse
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase Auth JWT verification (local HS256 — no network call)
# Get this from your self-hosted Supabase instance:
# Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Research
RESEARCH_ENGINE=llm
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# PDF rendering
USE_PUPPETEER=true  # set to false for local dev without Chrome

