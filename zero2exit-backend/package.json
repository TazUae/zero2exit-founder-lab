    "@sparticuz/chromium": "^123.0.0",
    "@trpc/server": "^11.11.0",
    "bullmq": "^5.12.0",
    "docx": "^9.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "ioredis": "^5.4.1",
    "langfuse": "^3.29.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.25.0",
    "pdfkit": "^0.17.2",
    "pino": "^9.5.0",
