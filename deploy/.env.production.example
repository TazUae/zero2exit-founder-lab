# ============================================================
# Production Environment Variables
# Copy to .env in the project root on your VPS
# ============================================================

# ─── Domain (used by Traefik for routing + SSL) ───
DOMAIN=zero2exit.com

# ─── Database ───
POSTGRES_USER=zero2exit
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_24
POSTGRES_DB=zero2exit

# ─── Clerk Auth ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── URLs ───
# Public origin for the Next.js app (what users see in the browser)
FRONTEND_URL=https://zero2exit.com
# Internal URL for the backend inside Docker (used by Next.js rewrites)
NEXT_PUBLIC_API_URL=http://backend:3000

# ─── LLM Providers (at least one required) ───
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# ─── AWS S3 ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_PREFIX=zero2exit-founder-

# ─── DocuSign ───
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://www.docusign.net/restapi

# ─── Resend (Email) ───
RESEND_API_KEY=re_...

# ─── Langfuse (Observability) ───
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Research ───
RESEARCH_ENGINE=kimi
PERPLEXITY_API_KEY=
